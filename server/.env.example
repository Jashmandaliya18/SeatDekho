PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/drama_booking
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Razorpay credentials (mock values for local testing bypass)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# SMTP Senders (Mailtrap or SMTP email credentials)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password_here
SENDER_EMAIL=your_email@gmail.com

# Google Client ID (OAuth credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Initial Seeding / Setup Passwords 
SEED_ADMIN_PASSWORD=your_desired_admin_password_here
SEED_VIEWER_PASSWORD=your_desired_viewer_password_here
ADMIN_INITIAL_PASSWORD=your_desired_admin_password_here
